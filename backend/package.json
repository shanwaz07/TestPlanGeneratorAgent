{
  "name": "test-plan-generator-backend",
  "version": "1.0.0",
  "description": "Backend API for Intelligent Test Plan Generator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "tool:jira": "ts-node tools/test_jira_connection.ts",
    "tool:groq": "ts-node tools/test_groq_connection.ts",
    "tool:openai": "ts-node tools/test_openai_connection.ts",
    "tool:ollama": "ts-node tools/test_ollama_connection.ts",
    "tool:all": "ts-node tools/test_jira_connection.ts && ts-node tools/test_groq_connection.ts && ts-node tools/test_openai_connection.ts && ts-node tools/test_ollama_connection.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "groq-sdk": "^0.5.0",
    "multer": "^2.0.0",
    "openai": "^4.47.1",
    "pdf-parse": "^1.1.1",
    "sql.js": "^1.12.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.4",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
